# HubSpot Service Key (PAT - Private App Token)
# Get this from: HubSpot Settings → Integrations → Service Keys
# Required scopes: tickets, conversations.read, sales-email-read
HUBSPOT_ACCESS_TOKEN=pat-na2-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your HubSpot portal ID (find it in your HubSpot URL)
HUBSPOT_PORTAL_ID=

# Number of parallel conversation fetches (default: 10)
# CONCURRENCY=10
